# ZIP-архивы
*.zip

# Резервные копии
*.bak
*.backup

# Системные папки Windows
System Volume Information/
$RECYCLE.BIN/

# Зависимости Node.js
node_modules/

# Папки IDE и редакторов
.vscode/
.idea/
*.swp

# Любые вложенные каталоги с определёнными именами (пример)
temp/
tmp/
dist/
build/

# Если нужно исключить все вложенные каталоги с определённым названием, например "backup":
**/backup/